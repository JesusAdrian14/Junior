---
import {
    skillsFrontend,
    skillsBackend,
    skillsToolsAndDevOps,
} from "../lib/info";

// Imagen por defecto para cuando falla la carga (puedes ponerla en public/)
const FALLBACK_IMAGE = "/placeholder-logo.png"; // O usa una URL externa: "https://via.placeholder.com/40x40?text=Logo"
---

<div class="container" id="skills">
    <h2>Habilidades</h2>

    <div class="skills-grid">
        <!-- Frontend -->
        <div class="skill-card">
            <div class="skill-header">Frontend</div>

            <div class="skill-items">
                {
                    skillsFrontend.map((skill) => (
                        <div class="skill-item">
                            <div class="icon-container">
                                <img
                                    src={skill.logo}
                                    alt={skill.name}
                                    class="skill-icon"
                                    loading="lazy"
                                />
                            </div>
                            <span class="skill-name">{skill.name}</span>
                        </div>
                    ))
                }
            </div>
        </div>

        <!-- Backend -->
        <div class="skill-card">
            <div class="skill-header">Backend</div>

            <div class="skill-items">
                {
                    skillsBackend.map((skill) => (
                        <div class="skill-item">
                            <div class="icon-container">
                                <img
                                    src={skill.logo}
                                    alt={skill.name}
                                    class="skill-icon"
                                    loading="lazy"
                                />
                            </div>
                            <span class="skill-name">{skill.name}</span>
                        </div>
                    ))
                }
            </div>
        </div>

        <!-- Tools & DevOps -->
        <div class="skill-card">
            <div class="skill-header">Tools & DevOps</div>

            <div class="skill-items">
                {
                    skillsToolsAndDevOps.map((skill) => (
                        <div class="skill-item">
                            <div class="icon-container">
                                <img
                                    src={skill.logo}
                                    alt={skill.name}
                                    class="skill-icon"
                                    loading="lazy"
                                />
                            </div>
                            <span class="skill-name">{skill.name}</span>
                        </div>
                    ))
                }
            </div>
        </div>
    </div>
</div>

<style>
    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 20px;
    }

    .container h2 {
        font-size: 2.5rem;
        font-weight: bold;
        color: var(--text-primary);
        margin-bottom: 3rem;
        text-align: center;
        background: linear-gradient(
            135deg,
            var(--accent-bright),
            var(--primary-accent)
        );
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .skills-grid {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: 2rem;
    }

    .skill-card {
        background: linear-gradient(
            135deg,
            var(--primary-light),
            var(--primary-dark)
        );
        border: 2px solid var(--border-color);
        border-radius: 12px;
        overflow: hidden;
        transition: all 0.3s ease;
        grid-column: span 2;
    }
    .skill-card:last-child:nth-child(odd) {
      grid-column: 2/ span 2;
    }

    .skill-card:hover {
        border-color: var(--accent-bright);
        transform: translateY(-8px);
        box-shadow: 0 15px 40px rgba(59, 130, 246, 0.25);
    }

    .skill-header {
        background: linear-gradient(
            135deg,
            var(--primary-accent),
            var(--accent-bright)
        );
        padding: 1rem;
        font-size: 1.3rem;
        font-weight: bold;
        color: white;
        text-align: center;
    }

    .skill-items {
        padding: 1.5rem;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));
        gap: 1rem;
    }

    .skill-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        padding: 1rem;
        background: rgba(59, 130, 246, 0.05);
        border: 1px solid var(--border-color);
        border-radius: 8px;
        transition: all 0.3s ease;
        text-align: center;
    }

    .skill-item:hover {
        background: rgba(59, 130, 246, 0.15);
        border-color: var(--accent-bright);
        transform: scale(1.05);
    }

    /* Contenedor para forzar el tamaño de las imágenes */
    .icon-container {
        width: 70px;
        height: 70px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    .skill-icon {
        width: 100%;
        height: 100%;
        object-fit: contain;
        display: block;
    }

    .skill-name {
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--text-primary);
    }

    @media (max-width: 768px) {
        .container {
            padding: 2rem 1rem;
        }

        .container h2 {
            font-size: 2rem;
        }

        .skills-grid {
            grid-template-columns: 1fr;
            gap: 1.5rem;
        }

        .skill-items {
            grid-template-columns: repeat(3, 1fr);
        }

        .icon-container {
            width: 40px;
            height: 40px;
        }
    }
</style>
