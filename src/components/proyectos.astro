---
<div class="proyectos-container" id="proyectos">
  <h2 class="text-title">Proyectos</h2>
  <div class="proyectos-grid">
    <!-- Proyecto 1 -->
    <div class="proyecto-card glass-effect">
      <div class="proyecto-imagen">
        <span class="icono-proyecto">💻</span>
      </div>
      <div class="proyecto-contenido">
        <h3>Proyecto Web</h3>
        <p>Aplicación web desarrollada con React y Node.js. Gestión de datos con PostgreSQL.</p>
        <div class="proyecto-tags">
          <span class="tag">React</span>
          <span class="tag">Node.js</span>
          <span class="tag">PostgreSQL</span>
        </div>
        <div class="proyecto-links">
          <a href="#" class="btn-primary">Ver Proyecto</a>
          <a href="#" class="btn-secondary">GitHub</a>
        </div>
      </div>
    </div>

    <!-- Proyecto 2 -->
    <div class="proyecto-card glass-effect">
      <div class="proyecto-imagen">
        <span class="icono-proyecto">🦀</span>
      </div>
      <div class="proyecto-contenido">
        <h3>Aplicación Desktop con Tauri</h3>
        <p>Aplicación de escritorio con Tauri y React. Interfaz moderna y rendimiento óptimo.</p>
        <div class="proyecto-tags">
          <span class="tag">Tauri</span>
          <span class="tag">React</span>
          <span class="tag">Rust</span>
        </div>
        <div class="proyecto-links">
          <a href="#" class="btn-primary">Ver Proyecto</a>
          <a href="#" class="btn-secondary">GitHub</a>
        </div>
      </div>
    </div>

    <!-- Proyecto 3 -->
    <div class="proyecto-card glass-effect">
      <div class="proyecto-imagen">
        <span class="icono-proyecto">🎨</span>
      </div>
      <div class="proyecto-contenido">
        <h3>Landing Page</h3>
        <p>Sitio web responsivo y moderno. Diseño limpio con animaciones suaves.</p>
        <div class="proyecto-tags">
          <span class="tag">HTML5</span>
          <span class="tag">CSS3</span>
          <span class="tag">JavaScript</span>
        </div>
        <div class="proyecto-links">
          <a href="#" class="btn-primary">Ver Proyecto</a>
          <a href="#" class="btn-secondary">GitHub</a>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .proyectos-container {
    padding: 4rem 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .proyectos-container h2 {
    text-align: center;
    margin-bottom: 3rem;
  }

  .proyectos-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }

  .proyecto-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border-color: rgba(255, 255, 255, 0.2);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.6), 0 0 0 1px rgba(255, 255, 255, 0.1);
    background: rgba(20, 20, 20, 0.3);
    backdrop-filter: blur(2px);
    border-radius: 20px;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .proyecto-card:hover {
  }

  .proyecto-imagen {
    background: linear-gradient(135deg, rgba(255,255,255,0.2), rgba(255,255,255,0.05));
    height: 160px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .icono-proyecto {
    font-size: 4.5rem;
    filter: drop-shadow(0 4px 10px rgba(255, 255, 255, 0.2));
    transition: transform 0.3s ease;
  }

  .proyecto-card:hover .icono-proyecto {
    transform: scale(1.1);
  }

  .proyecto-contenido {
    padding: 2rem;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .proyecto-contenido h3 {
    font-size: 1.5rem;
    color: var(--text-primary);
    margin-bottom: 1rem;
    text-shadow: var(--text-shadow-white);
    font-weight: 600;
  }

  .proyecto-contenido p {
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
    flex-grow: 1;
    line-height: 1.7;
    font-size: 1rem;
  }

  .proyecto-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 2rem;
  }

  .tag {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--text-secondary);
    padding: 0.3rem 1rem;
    border-radius: 30px;
    font-size: 0.85rem;
    font-weight: 500;
    backdrop-filter: blur(5px);
    transition: all 0.3s ease;
  }

  .tag:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.2);
    color: var(--text-primary);
  }

  .proyecto-links {
    display: flex;
    gap: 1rem;
  }

  .btn-primary,
  .btn-secondary {
    padding: 0.8rem 1.5rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
    font-size: 0.95rem;
    text-align: center;
    flex: 1;
    border: none;
    cursor: pointer;
  }

  .btn-primary {
    background: rgba(255, 255, 255, 0.9);
    color: #000;
    box-shadow: 0 4px 15px rgba(255, 255, 255, 0.2);
  }

  .btn-primary:hover {
    background: #ffffff;
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(255, 255, 255, 0.4);
  }

  .btn-secondary {
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: var(--text-primary);
    backdrop-filter: blur(5px);
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.6);
    transform: translateY(-3px);
    box-shadow: 0 4px 15px rgba(255, 255, 255, 0.15);
  }

  @media (max-width: 768px) {
    .proyectos-container {
      padding: 2rem 1rem;
    }

    .proyecto-links {
      flex-direction: column;
    }

    .btn-primary, .btn-secondary {
      width: 100%;
    }
  }
</style>
