<div class="container" id="proyectos">
  <h2>Proyectos</h2>
  <div class="proyectos-grid">
    <!-- Proyecto 1 -->
    <div class="proyecto-card">
      <div class="proyecto-imagen">
        <span class="icono-proyecto">💻</span>
      </div>
      <div class="proyecto-contenido">
        <h3>Proyecto Web</h3>
        <p>Aplicación web desarrollada con React y Node.js. Gestión de datos con PostgreSQL.</p>
        <div class="proyecto-tags">
          <span class="tag">React</span>
          <span class="tag">Node.js</span>
          <span class="tag">PostgreSQL</span>
        </div>
        <div class="proyecto-links">
          <a href="#" class="btn-primary">Ver Proyecto</a>
          <a href="#" class="btn-secondary">GitHub</a>
        </div>
      </div>
    </div>

    <!-- Proyecto 2 -->
    <div class="proyecto-card">
      <div class="proyecto-imagen">
        <span class="icono-proyecto">🦀</span>
      </div>
      <div class="proyecto-contenido">
        <h3>Aplicación Desktop con Tauri</h3>
        <p>Aplicación de escritorio con Tauri y React. Interfaz moderna y rendimiento óptimo.</p>
        <div class="proyecto-tags">
          <span class="tag">Tauri</span>
          <span class="tag">React</span>
          <span class="tag">Rust</span>
        </div>
        <div class="proyecto-links">
          <a href="#" class="btn-primary">Ver Proyecto</a>
          <a href="#" class="btn-secondary">GitHub</a>
        </div>
      </div>
    </div>

    <!-- Proyecto 3 -->
    <div class="proyecto-card">
      <div class="proyecto-imagen">
        <span class="icono-proyecto">🎨</span>
      </div>
      <div class="proyecto-contenido">
        <h3>Landing Page</h3>
        <p>Sitio web responsivo y moderno. Diseño limpio con animaciones suaves.</p>
        <div class="proyecto-tags">
          <span class="tag">HTML5</span>
          <span class="tag">CSS3</span>
          <span class="tag">JavaScript</span>
        </div>
        <div class="proyecto-links">
          <a href="#" class="btn-primary">Ver Proyecto</a>
          <a href="#" class="btn-secondary">GitHub</a>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .container {
    padding: 4rem 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .container h2 {
    font-size: 2.5rem;
    font-weight: bold;
    color: var(--text-primary);
    margin-bottom: 3rem;
    text-align: center;
    background: linear-gradient(135deg, var(--accent-bright), var(--primary-accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .proyectos-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .proyecto-card {
    background: linear-gradient(135deg, var(--primary-light), var(--primary-dark));
    border: 2px solid var(--border-color);
    border-radius: 12px;
    overflow: hidden;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .proyecto-card:hover {
    border-color: var(--accent-bright);
    transform: translateY(-8px);
    box-shadow: 0 15px 40px rgba(59, 130, 246, 0.25);
  }

  .proyecto-imagen {
    background: linear-gradient(135deg, var(--primary-accent), var(--accent-bright));
    height: 150px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 2px solid var(--border-color);
  }

  .icono-proyecto {
    font-size: 4rem;
  }

  .proyecto-contenido {
    padding: 2rem;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .proyecto-contenido h3 {
    font-size: 1.4rem;
    color: var(--accent-bright);
    margin-bottom: 0.8rem;
  }

  .proyecto-contenido p {
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
    flex-grow: 1;
    line-height: 1.6;
  }

  .proyecto-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .tag {
    background: rgba(59, 130, 246, 0.1);
    border: 1px solid var(--accent-bright);
    color: var(--accent-bright);
    padding: 0.3rem 0.8rem;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 500;
  }

  .proyecto-links {
    display: flex;
    gap: 1rem;
  }

  .btn-primary,
  .btn-secondary {
    padding: 0.7rem 1.5rem;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
    font-size: 0.95rem;
    text-align: center;
  }

  .btn-primary {
    background: var(--accent-bright);
    color: white;
    flex: 1;
  }

  .btn-primary:hover {
    background: #2563eb;
    transform: scale(1.05);
  }

  .btn-secondary {
    background: transparent;
    border: 2px solid var(--accent-bright);
    color: var(--accent-bright);
    flex: 1;
  }

  .btn-secondary:hover {
    background: rgba(59, 130, 246, 0.1);
  }

  @media (max-width: 768px) {
    .container {
      padding: 2rem 1rem;
    }

    .container h2 {
      font-size: 2rem;
    }

    .proyecto-links {
      flex-direction: column;
    }
  }
</style>
