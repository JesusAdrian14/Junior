<div class="container-presentacion" id="presentacion">
    <div class="contenido">
        <div class="texto-presentacion">
            <div class="saludo text-light">Hola, soy</div>
            <h1 class="nombre text-light">Jesus Camacho</h1>
            <div class="titulo text-light">Desarrollador Web Full Stack</div>
            <p class="descripcion">
                Especializado en <span class="highlight text-light"
                    >backend</span
                > y <span class="highlight text-light">frontend</span>, con
                experiencia en <span class="highlight text-light">Tauri</span> para
                aplicaciones de escritorio. Tengo 15 años y soy apasionado por crear
                aplicaciones web modernas y eficientes. Me encanta aprender nuevas
                tecnologías y mejorar constantemente mis habilidades.
            </p>
            <div class="acciones">
                <a
                    href="/jesus_adrian_camacho_casierra_cv.pdf"
                    class="btn-principal">Ver mi CV</a
                >
                <a
                    href="https://wa.me/573154352572?text=hola%20mejor%20mejor%20programador"
                    class="btn-secundario">Contactame por WhatsApp</a
                >
            </div>
        </div>
        {
            /*<div class="imagen-contenedor">
            <div class="image-me"></div>
        </div>*/
        }
    </div>
</div>

<style>
    .container-presentacion {
        padding: 0 2rem;
        width: 100%;
        max-width: 1200px;
        margin: 0 auto;
        min-height: 80vh;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .contenido {
        display: flex;
        gap: 4rem;
        align-items: center;
        justify-content: center;
        width: 100%;
    }
    .texto-presentacion {
        width: 700px;
    }

    .saludo {
        font-size: 1.2rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
    }
    .text-light {
        text-shadow: 0 0 13px white !important;
        color: white !important;
    }

    .nombre {
        font-size: 3.5rem;
        font-weight: bold;
        margin: 0.5rem 0 1rem 0;
        background-clip: text;
    }

    .titulo {
        font-size: 1.8rem;
        margin-bottom: 1.5rem;
        font-weight: 600;
    }

    .descripcion {
        color: var(--text-secondary);
        font-size: 1.3rem;
        line-height: 1.8;
        margin-bottom: 2rem;
    }

    .highlight {
        font-weight: 600;
    }

    .acciones {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .btn-principal,
    .btn-secundario {
        padding: 1rem 2rem;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        font-size: 1rem;
        transition: all 0.3s ease;
        border: none;
        cursor: pointer;
        display: inline-block;
    }

    .btn-principal {
        background: white;
        color: rgb(0, 0, 0);
    }

    .btn-principal:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 25px rgb(255, 255, 255);
    }

    .btn-secundario {
        background: transparent;
        border: 2px solid white;
        color: white;
    }

    .btn-secundario:hover {
        background: rgba(37, 211, 102);
        box-shadow: 0 10px 25px rgba(37, 211, 102, 0.3);
        transform: translateY(-3px);
    }

    .imagen-contenedor {
        display: none;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .image-me {
        display: none;
        width: 280px;
        height: 280px;
        border-radius: 50%;
        background: linear-gradient(
            135deg,
            var(--primary-accent),
            var(--accent-bright)
        );
        border: 3px solid var(--border-color);
        box-shadow: 0 0 40px rgba(59, 130, 246, 0.3);
        animation: float 3s ease-in-out infinite;
    }

    @keyframes float {
        0%,
        100% {
            transform: translateY(0px);
        }
        50% {
            transform: translateY(-20px);
        }
    }

    @media (max-width: 1024px) {
        .nombre {
            font-size: 2.8rem;
        }

        .titulo {
            font-size: 1.5rem;
        }
    }

    @media (max-width: 768px) {
        .container-presentacion {
            padding: 3rem 1rem;
            min-height: 100vh;
        }

        .contenido {
            grid-template-columns: 1fr;
            gap: 2rem;
        }

        .nombre {
            font-size: 2.2rem;
        }

        .titulo {
            font-size: 1.3rem;
        }

        .descripcion {
            font-size: 1rem;
        }

        .image-me {
            width: 200px;
            height: 200px;
        }

        .acciones {
            flex-direction: column;
        }

        .btn-principal,
        .btn-secundario {
            width: 100%;
            text-align: center;
        }
    }
</style>
