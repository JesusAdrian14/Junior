---
import { Image } from "astro:assets";

// navbar.astro
---

<nav class="navbar">
    <div class="navbar-container">
        <ul class="nav-menu">
            <li class="nav-item">
                <a href="#presentacion" title="Me presento...." class="nav-link">Inicio</a>
            </li>
            <li class="nav-item">
                <a href="#skills" title="Habilidades dominadas" class="nav-link">Habilidades</a>
            </li>
            <li class="nav-item">
                <a href="#proyectos" title="Proyectos funcionales" class="nav-link">Proyectos</a>
            </li>
            <li class="nav-item">
                <a href="#contacto" title="Contactame" class="nav-link">Contacto</a>
            </li>
        </ul>
    </div>
    <div class="container-redes">
        <ul class="nav-menu">
            <li class="nav-item">
                <a href="https://github.com/JesusAdrian14" target="_blank" rel="noopener">
                    <img class="img-red" src="/icons8-github-48.png" title="GitHub" alt="GitHub" />
                </a>
                <a href="https://wa.me/tunumerodewhatsapp" target="_blank" rel="noopener">
                    <img class="img-red-whatsapp" src="/icons8-whatsapp-50.png" title="WhatsApp" alt="Ir a WhatsApp" />
                </a>
            </li>
        </ul>
    </div>
</nav>

<style>
    .navbar {
        max-width: 1200px;
        width: 100%;
        top: 5px;
        left: 0;
        display: flex;
        justify-content: flex-end;
        gap: 19rem;
        align-items: center;
        z-index: 1000;
        animation: slideDown 0.5s ease;
        position: sticky;
        background: transparent;
        backdrop-filter: none;
        -webkit-backdrop-filter: none;
    }

    @keyframes slideDown {
        from {
            transform: translateY(-100%);
            opacity: 0;
        }
        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    .navbar-container {
        width: fit-content;
        border: 1px solid hsl(white/0.5);
        border-radius: 50px;
        padding: 0.2rem 1rem;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
        transition: all 0.3s ease;
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(4px);
        -webkit-backdrop-filter: blur(4px);
    }

    .container-redes {
        width: fit-content;
    }

    .nav-menu {
        display: flex;
        list-style: none;
        gap: 2.5rem;
        margin: 0;
        padding: 0;
    }

    .nav-item {
        margin: 0;
        position: relative;
    }

    .nav-link {
        color: rgb(255, 255, 255);
        text-decoration: none;
        font-size: 1.3rem;
        font-weight: 500;
        transition: all 0.3s ease;
        position: relative;
        opacity: 0.8;
        letter-spacing: 0.5px;
    }

    .nav-link:hover {
        opacity: 1;
        color: white;
    }

    .nav-link::after {
        content: "";
        position: absolute;
        bottom: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 0;
        height: 2px;
        background: #ffffff;
        transition: width 100ms ease-in-out;
        border-radius: 2px;
    }

    .nav-link:hover::after {
        width: 100%;
    }

    .img-red {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        margin-left: 10px;
        transition: transform 0.3s ease;
        background: white;
    }

    .img-red:hover {
        transform: scale(1.1);
    }

    .img-red-whatsapp {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        margin-left: 10px;
        transition: transform 0.3s ease;
    }

    .img-red-whatsapp:hover {
        transform: scale(1.1);
    }

    @media (max-width: 768px) {
        .navbar {
            flex-direction: column;
            gap: 1rem;
        }

        .navbar-container,
        .container-redes {
            width: 90%;
            justify-content: center;
        }

        .nav-menu {
            gap: 1.5rem;
            justify-content: center;
        }

        .nav-link {
            font-size: 1.1rem;
        }
    }

    @media (max-width: 480px) {
        .navbar {
            gap: 0.5rem;
        }

        .nav-link {
            font-size: 0.9rem;
        }

        .img-red, .img-red-whatsapp {
            width: 35px;
            height: 35px;
        }
    }
</style>
