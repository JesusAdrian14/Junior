<nav class="navbar">
  <div class="navbar-container">
    <div class="navbar-logo">
      <span class="logo-text">Junior Dev</span>
    </div>
    <ul class="nav-menu">
      <li class="nav-item">
        <a href="#presentacion" title="Me presento...." class="nav-link">Inicio</a>
      </li>
      <li class="nav-item">
        <a href="#skills" title="Habilidades dominadas" class="nav-link">Habilidades</a>
      </li>
      <li class="nav-item">
        <a href="#proyectos" title="Proyectos funcionales" class="nav-link">Proyectos</a>
