<style>
    .navbar {
        max-width: 1200px;
        width: 100%;
        top: 5px;
        left: 0;
        display: flex;
        justify-content: flex-end;
        gap: 19rem;
        align-items: center;
        z-index: 1000;
        animation: slideDown 0.5s ease;
        position: sticky;
        background: transparent;
        backdrop-filter: none;
        -webkit-backdrop-filter: none;
    }

    @keyframes slideDown {
        from {
            transform: translateY(-100%);
            opacity: 0;
        }
        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    .navbar-container {
        width: fit-content;
        border: 1px solid white;
        border-radius: 50px;
        padding: 0.2rem 1rem;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
        transition: all 0.3s ease;
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(4px);
        -webkit-backdrop-filter: blur(4px);
    }

    .container-redes {
        width: fit-content;
    }

    .nav-menu {
        display: flex;
        list-style: none;
        gap: 2.5rem;
        margin: 0;
        padding: 0;
    }

    .nav-item {
        margin: 0;
        position: relative;
    }

    .nav-link {
        color: rgb(255, 255, 255);
        text-decoration: none;
        font-size: 1.3rem;
        font-weight: 500;
        transition: all 0.3s ease;
        position: relative;
        opacity: 0.8;
        letter-spacing: 0.5px;
    }

    .nav-link:hover {
        opacity: 1;
        color: white;
    }

    .nav-link::after {
        content: "";
        position: absolute;
        bottom: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 0;
        height: 2px;
        background: #ffffff;
        transition: width 100ms ease-in-out;
        border-radius: 2px;
    }

    .nav-link:hover::after {
        width: 100%;
    }

    .img-red-github {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        margin-left: 10px;
        background: white;
        transition: all 0.3s ease;
        position: relative;
        z-index: 2;
    }

    .img-red-whatsapp {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        margin-left: 10px;
        transition: all 0.3s ease;
        position: relative;
        z-index: 2;
    }

    .fire-link {
        position: relative;
        display: inline-block;
        text-decoration: none;
    }

    /* Estilos base para todas las brasas - MÁS GRANDES */
    .fire-link .ember {
        position: absolute;
        top: 50%;
        left: 50%;
        width: 12px;
        height: 12px;
        border-radius: 50%;
        opacity: 0;
        pointer-events: none;
        filter: blur(3px);
        z-index: 1;
    }

    /* GitHub embers - colores naranja/rojo */
    .github-fire .ember {
        background: radial-gradient(circle, #ffaa00 0%, #ff4500 70%);
        box-shadow:
            0 0 20px #ff6b00,
            0 0 40px #ff4500;
    }

    /* WhatsApp embers - colores verde esmeralda */
    .whatsapp-fire .ember {
        background: radial-gradient(circle, #88ffaa 0%, #00cc66 70%);
        box-shadow:
            0 0 20px #00ff88,
            0 0 40px #00cc66;
    }

    /* Activación al hacer hover */
    .github-fire:hover .ember,
    .whatsapp-fire:hover .ember {
        animation-timing-function: cubic-bezier(0.2, 0.9, 0.3, 1);
    }

    /* Asignar animaciones más lentas y pesadas */
    .github-fire:hover .ember1,
    .whatsapp-fire:hover .ember1 {
        animation: fallHeavy1 1s ease-out infinite;
    }
    .github-fire:hover .ember2,
    .whatsapp-fire:hover .ember2 {
        animation: fallHeavy2 1.1s ease-out infinite;
    }
    .github-fire:hover .ember3,
    .whatsapp-fire:hover .ember3 {
        animation: fallHeavy3 1.2s ease-out infinite;
    }
    .github-fire:hover .ember4,
    .whatsapp-fire:hover .ember4 {
        animation: fallHeavy4 0.95s ease-out infinite;
    }
    .github-fire:hover .ember5,
    .whatsapp-fire:hover .ember5 {
        animation: fallHeavy5 1.15s ease-out infinite;
    }
    .github-fire:hover .ember6,
    .whatsapp-fire:hover .ember6 {
        animation: fallHeavy6 1s ease-out infinite 0.15s;
    }
    .github-fire:hover .ember7,
    .whatsapp-fire:hover .ember7 {
        animation: fallHeavy7 1.1s ease-out infinite 0.2s;
    }
    .github-fire:hover .ember8,
    .whatsapp-fire:hover .ember8 {
        animation: fallHeavy8 1.2s ease-out infinite 0.25s;
    }
    .github-fire:hover .ember9,
    .whatsapp-fire:hover .ember9 {
        animation: fallHeavy9 0.95s ease-out infinite 0.3s;
    }
    .github-fire:hover .ember10,
    .whatsapp-fire:hover .ember10 {
        animation: fallHeavy10 1.15s ease-out infinite 0.35s;
    }
    .github-fire:hover .ember11,
    .whatsapp-fire:hover .ember11 {
        animation: fallHeavy1 1s ease-out infinite 0.4s;
    }
    .github-fire:hover .ember12,
    .whatsapp-fire:hover .ember12 {
        animation: fallHeavy2 1.1s ease-out infinite 0.45s;
    }
    .github-fire:hover .ember13,
    .whatsapp-fire:hover .ember13 {
        animation: fallHeavy3 1.2s ease-out infinite 0.5s;
    }
    .github-fire:hover .ember14,
    .whatsapp-fire:hover .ember14 {
        animation: fallHeavy4 0.95s ease-out infinite 0.55s;
    }
    .github-fire:hover .ember15,
    .whatsapp-fire:hover .ember15 {
        animation: fallHeavy5 1.15s ease-out infinite 0.6s;
    }

    /* Animaciones pesadas con mayor recorrido y escalado */
    @keyframes fallHeavy1 {
        0% {
            opacity: 1;
            transform: translate(-50%, 0) scale(1);
        }
        20% {
            transform: translate(calc(-50% + 8px), 25px) scale(1.3);
        }
        40% {
            transform: translate(calc(-50% - 6px), 50px) scale(1.1);
        }
        60% {
            transform: translate(calc(-50% + 7px), 75px) scale(0.9);
        }
        80% {
            transform: translate(calc(-50% - 5px), 100px) scale(0.6);
        }
        100% {
            opacity: 0;
            transform: translate(calc(-50% + 6px), 130px) scale(0.3);
        }
    }

    @keyframes fallHeavy2 {
        0% {
            opacity: 1;
            transform: translate(-50%, 0) scale(1);
        }
        25% {
            transform: translate(calc(-50% - 10px), 30px) scale(1.4);
        }
        50% {
            transform: translate(calc(-50% + 12px), 60px) scale(1);
        }
        75% {
            transform: translate(calc(-50% - 8px), 90px) scale(0.7);
        }
        100% {
            opacity: 0;
            transform: translate(calc(-50% + 10px), 130px) scale(0.3);
        }
    }

    @keyframes fallHeavy3 {
        0% {
            opacity: 1;
            transform: translate(-50%, 0) scale(1);
        }
        30% {
            transform: translate(calc(-50% + 9px), 35px) scale(1.3);
        }
        60% {
            transform: translate(calc(-50% - 10px), 70px) scale(0.9);
        }
        90% {
            transform: translate(calc(-50% + 8px), 105px) scale(0.5);
        }
        100% {
            opacity: 0;
            transform: translate(calc(-50% - 7px), 130px) scale(0.3);
        }
    }

    @keyframes fallHeavy4 {
        0% {
            opacity: 1;
            transform: translate(-50%, 0) scale(1);
        }
        20% {
            transform: translate(calc(-50% - 8px), 25px) scale(1.4);
        }
        40% {
            transform: translate(calc(-50% + 9px), 50px) scale(1.1);
        }
        60% {
            transform: translate(calc(-50% - 9px), 75px) scale(0.8);
        }
        80% {
            transform: translate(calc(-50% + 8px), 100px) scale(0.5);
        }
        100% {
            opacity: 0;
            transform: translate(calc(-50% - 8px), 130px) scale(0.3);
        }
    }

    @keyframes fallHeavy5 {
        0% {
            opacity: 1;
            transform: translate(-50%, 0) scale(1);
        }
        25% {
            transform: translate(calc(-50% + 12px), 30px) scale(1.4);
        }
        50% {
            transform: translate(calc(-50% - 10px), 60px) scale(1);
        }
        75% {
            transform: translate(calc(-50% + 9px), 90px) scale(0.6);
        }
        100% {
            opacity: 0;
            transform: translate(calc(-50% - 9px), 130px) scale(0.3);
        }
    }

    @keyframes fallHeavy6 {
        0% {
            opacity: 1;
            transform: translate(-50%, 0) scale(1);
        }
        20% {
            transform: translate(calc(-50% + 7px), 25px) scale(1.3);
        }
        40% {
            transform: translate(calc(-50% - 8px), 50px) scale(1);
        }
        60% {
            transform: translate(calc(-50% + 9px), 75px) scale(0.8);
        }
        80% {
            transform: translate(calc(-50% - 6px), 100px) scale(0.5);
        }
        100% {
            opacity: 0;
            transform: translate(calc(-50% + 8px), 130px) scale(0.3);
        }
    }

    @keyframes fallHeavy7 {
        0% {
            opacity: 1;
            transform: translate(-50%, 0) scale(1);
        }
        30% {
            transform: translate(calc(-50% - 9px), 35px) scale(1.4);
        }
        60% {
            transform: translate(calc(-50% + 10px), 70px) scale(0.9);
        }
        90% {
            transform: translate(calc(-50% - 8px), 105px) scale(0.5);
        }
        100% {
            opacity: 0;
            transform: translate(calc(-50% + 9px), 130px) scale(0.3);
        }
    }

    @keyframes fallHeavy8 {
        0% {
            opacity: 1;
            transform: translate(-50%, 0) scale(1);
        }
        25% {
            transform: translate(calc(-50% + 8px), 30px) scale(1.3);
        }
        50% {
            transform: translate(calc(-50% - 9px), 60px) scale(0.9);
        }
        75% {
            transform: translate(calc(-50% + 10px), 90px) scale(0.6);
        }
        100% {
            opacity: 0;
            transform: translate(calc(-50% - 8px), 130px) scale(0.3);
        }
    }

    @keyframes fallHeavy9 {
        0% {
            opacity: 1;
            transform: translate(-50%, 0) scale(1);
        }
        20% {
            transform: translate(calc(-50% - 7px), 25px) scale(1.4);
        }
        40% {
            transform: translate(calc(-50% + 8px), 50px) scale(1.1);
        }
        60% {
            transform: translate(calc(-50% - 9px), 75px) scale(0.8);
        }
        80% {
            transform: translate(calc(-50% + 7px), 100px) scale(0.5);
        }
        100% {
            opacity: 0;
            transform: translate(calc(-50% - 7px), 130px) scale(0.3);
        }
    }

    @keyframes fallHeavy10 {
        0% {
            opacity: 1;
            transform: translate(-50%, 0) scale(1);
        }
        30% {
            transform: translate(calc(-50% + 10px), 35px) scale(1.4);
        }
        60% {
            transform: translate(calc(-50% - 9px), 70px) scale(0.9);
        }
        90% {
            transform: translate(calc(-50% + 9px), 105px) scale(0.5);
        }
        100% {
            opacity: 0;
            transform: translate(calc(-50% - 8px), 130px) scale(0.3);
        }
    }

    .img-red-github:hover {
        transform: scale(1.1);
        filter: brightness(1.2);
    }

    .img-red-whatsapp:hover {
        transform: scale(1.1);
        filter: brightness(1.2);
    }

    @media (max-width: 768px) {
        .navbar {
            flex-direction: column;
            gap: 1rem;
        }

        .navbar-container,
        .container-redes {
            width: 90%;
            justify-content: center;
        }

        .nav-menu {
            gap: 1.5rem;
            justify-content: center;
        }

        .nav-link {
            font-size: 1.1rem;
        }
    }

    @media (max-width: 480px) {
        .navbar {
            gap: 0.5rem;
        }

        .nav-link {
            font-size: 0.9rem;
        }

        .img-red-github,
        .img-red-whatsapp {
            width: 35px;
            height: 35px;
        }
    }
</style>
