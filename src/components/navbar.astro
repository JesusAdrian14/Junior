                    <span class="ember ember11"></span>
                    <span class="ember ember12"></span>
                    <span class="ember ember13"></span>
                    <span class="ember ember14"></span>
                    <span class="ember ember15"></span>
                </a>
                <a
                    href="https://wa.me/573154352572?text=hola%20mejor%20programador"
                    target="_blank"
                    rel="noopener"
                    class="fire-link whatsapp-fire"
                >
                    <img
                        class="img-red-whatsapp"
                        src="/icons8-whatsapp-50.png"
                        title="WhatsApp"
                        alt="Ir a WhatsApp"
                    />
                    <span class="ember ember1"></span>
                    <span class="ember ember2"></span>
                    <span class="ember ember3"></span>
