---
import "../global.css";
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="generator" content={Astro.generator} />
        <meta
            name="description"
            content="Jesus Camacho - Desarrollador Web Full Stack"
        />
        <title>Junior Dev - Portafolio</title>
    </head>
    <body>
        <div class="body-c">
            <slot />
        </div>
    </body>
</html>

<style is:global>
    html,
    body {
        margin: 0;
        width: 100%;
        height: 100%;
        overflow: hidden;
        background: url("/vtJYvr2.png");
        background-size: contain;
    }
    .body-c {
        margin: 0;
        width: 100%;
        height: 100%;
        scroll-behavior: smooth;
        overflow: auto;
    }

    ::-webkit-scrollbar {
        width: 10px;
    }

    ::-webkit-scrollbar-track {
        background: var(--bg-dark);
    }

    ::-webkit-scrollbar-thumb {
        background: var(--primary-accent);
        border-radius: 5px;
    }

    ::-webkit-scrollbar-thumb:hover {
        background: var(--accent-bright);
    }
</style>
